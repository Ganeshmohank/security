# Rename this file to `.env` and paste your key below.
# secscan auto-loads it at startup, no extra `export` needed.

# --- OpenAI / ChatGPT (preferred) -------------------------------------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_llm_key

# --- OpenRouter (alternative, multi-model gateway) --------------------
# Leave commented unless you are using OpenRouter instead of OpenAI.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_api_llm_key
